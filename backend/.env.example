PORT=3000
NODE_ENV=development
APP_DATA_FILE=./data/app-data.local.json
CORS_ORIGIN=http://localhost:8080

# Local PostgreSQL configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maid_agency_db
DB_SSL=false

# Preferred backend connection
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase configuration
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-SUPABASE-ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SUPABASE-SERVICE-ROLE-KEY]

# OpenAI configuration
OPENAI_API_KEY=[YOUR-OPENAI-API-KEY]
OPENAI_MODEL=gpt-4o-mini

# SMTP email configuration for "Tell your friend"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_POOL=true
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_TLS_MIN_VERSION=TLSv1.2
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_USER=[YOUR-SMTP-USERNAME]
SMTP_PASS=[YOUR-SMTP-PASSWORD-OR-APP-PASSWORD]
SMTP_FROM=Helped <[YOUR-SMTP-USERNAME]>
MAIL_TELL_FRIEND_MAX_MESSAGE_BYTES=5000
MAIL_SEND_TIMEOUT_MS=8000

# Optional HTTP email provider fallback for environments where SMTP is blocked
MAIL_PROVIDER=smtp
RESEND_API_KEY=
RESEND_FROM="Helped <no-reply@yourdomain.com>"

# Make.com configuration
# Generic fallback webhook used by POST /api/send-to-make when no scenario-specific URL exists
MAKE_WEBHOOK_URL=https://hook.make.com/[YOUR-GENERIC-WEBHOOK]

# Optional scenario-specific overrides
MAKE_WEBHOOK_URL_LEAD_PIPELINE=https://hook.make.com/[YOUR-LEAD-WEBHOOK]
MAKE_WEBHOOK_URL_INQUIRY_PIPELINE=https://hook.make.com/[YOUR-INQUIRY-WEBHOOK]
MAKE_WEBHOOK_URL_MATCHING_PIPELINE=https://hook.make.com/[YOUR-MATCHING-WEBHOOK]
MAKE_WEBHOOK_URL_NOTIFICATION_PIPELINE=https://hook.make.com/[YOUR-NOTIFICATION-WEBHOOK]
