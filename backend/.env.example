PORT=3000
NODE_ENV=development

# Local PostgreSQL configuration
# Use this block for local development with your own Postgres instance.
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maid_agency_db
DB_SSL=false

# Supabase configuration
# Preferred backend connection: paste the Supabase pooled or direct Postgres URL here.
# Example:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=

# Optional explicit Supabase values for scripts, future realtime, or service integrations.
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# If you prefer DB_* values instead of DATABASE_URL, use the Supabase database host:
# DB_USER=postgres
# DB_PASSWORD=[YOUR-DATABASE-PASSWORD]
# DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_SSL=true
