# Legacy Node/Express backend (backend/) only
DATABASE_URL=postgresql://user:pass@host:port/db
PORT=3000
CORS_ORIGIN=http://localhost:8080
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_POOL=true
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_TLS_MIN_VERSION=TLSv1.2
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM="Helped <your-smtp-username>"
MAIL_TELL_FRIEND_MAX_MESSAGE_BYTES=5000
MAIL_SEND_TIMEOUT_MS=8000

# Optional HTTP email provider fallback for environments where SMTP is blocked
MAIL_PROVIDER=smtp
RESEND_API_KEY=
RESEND_FROM="Helped <no-reply@yourdomain.com>"

# Cloudflare Worker (functions/api/[[...path]].ts) storage (recommended)
# Use `.dev.vars` for `wrangler dev`, and `wrangler secret put` for production.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_APP_DATA_TABLE=app_data
SUPABASE_APP_DATA_ID=default
